# ─────────────────────────────────────────────────────────────────────────────
# Deepgram Voice Agent — Beispiel-Konfiguration. Kopieren nach `.env` und ausfüllen.
# Dasselbe Image läuft lokal wie in Prod — der Unterschied steckt nur in dieser Datei.
# ─────────────────────────────────────────────────────────────────────────────

# --- Deepgram ---------------------------------------------------------------
DEEPGRAM_API_KEY=

# --- LLM (Think + Summary) --------------------------------------------------
# Anbindung der LLMs. Standard: requesty (OpenAI-kompatibler Router).
# Umschaltbar auf ein von Deepgram integriert gehostetes Modell (think.source=deepgram).
LLM_PROVIDER=requesty
REQUESTY_API_KEY=
REQUESTY_BASE_URL=https://router.requesty.ai/v1
# Default-Modell (überschreibbar pro Agent in der DB)
LLM_MODEL=openai/gpt-4o

# --- MongoDB ----------------------------------------------------------------
# Lokale Container-Instanz ODER externes (repliziertes) Set.
MONGO_URI=mongodb://127.0.0.1:27017/voiceagent
# false => supervisord startet KEIN lokales mongod (externe DB via MONGO_URI nutzen)
USE_LOCAL_MONGO=true

# --- Asterisk / ARI ---------------------------------------------------------
ARI_URL=http://127.0.0.1:8088
ARI_USERNAME=voiceagent
ARI_PASSWORD=
ARI_APP=voice-office-hub
# true => Asterisk läuft als Prozess im selben Container (Dev-Default / Appliance)
# false => externe PBX wird genutzt
EMBED_ASTERISK=true

# --- SIP-Trunk (Appliance, ENV-gesteuert; nur bei EMBED_ASTERISK=true) -------
# true => der entrypoint generiert pjsip_trunk.conf aus den TRUNK_*-Werten (von pjsip.conf
#         per #include geladen). false => kein Trunk (Dev nutzt Softphone). Mehrere Trunks /
#         Verwaltung über die Admin-UI sind als spätere Ausbaustufe vorgesehen.
TRUNK_ENABLED=false
# SIP-Zugangsdaten des Providers (z. B. SIPGate-Trunk-Account).
TRUNK_SIP_ID=
TRUNK_SIP_PASSWORD=
# Provider-SIP-Server (Default für SIPGate Trunking).
TRUNK_SERVER=sipconnect.sipgate.de
# Erlaubte Codecs (Asterisk-Syntax).
TRUNK_CODECS=!all,g722,alaw,ulaw

# --- Audio (Telefonie) ------------------------------------------------------
# Medien-Transport: "audiosocket" (TCP, robust, empfohlen) oder "rtp" (UDP).
MEDIA_TRANSPORT=audiosocket
# Format: "slin"=8kHz, "slin16"=16kHz, "ulaw"=8kHz µ-law. AudioSocket-Default: slin/8000.
AUDIO_ENCODING=linear16
AUDIO_SAMPLE_RATE=8000
EXTERNAL_MEDIA_FORMAT=slin
# Host:Port, auf dem unser Server den externalMedia-RTP/AudioSocket-Stream empfängt
EXTERNAL_MEDIA_HOST=127.0.0.1
EXTERNAL_MEDIA_PORT=8090

# --- Default-Agent (Fallback, wenn keine DDI in `agents` passt) -------------
# Modus: "agent" (KI beantwortet) oder "passthrough" (Anruf an PASSTHROUGH_TARGET
# durchleiten + aufnehmen + nach Auflegen batch-transkribieren).
DEFAULT_MODE=agent
DEFAULT_AGENT_PROMPT=Du bist ein hilfreicher Telefon-Assistent. Antworte in der Sprache des Anrufers.
DEFAULT_AGENT_GREETING=Hallo! Wie kann ich Ihnen helfen?
DEFAULT_LISTEN_MODEL=nova-3
DEFAULT_SPEAK_MODEL=aura-2-thalia-en

# --- Weiterleitung ----------------------------------------------------------
# Ziel für Passthrough-Modus / Fallback-Transfer
PASSTHROUGH_TARGET=
# Sekunden, die auf Annahme gewartet wird, bevor der Agent zurückkehrt
TRANSFER_TIMEOUT=30

# --- Aufnahme ---------------------------------------------------------------
RECORDING_PATH=/data/recordings

# --- Post-Call Summary (Default-Agent) --------------------------------------
SUMMARY_ENABLED=false
SUMMARY_PROMPT=Fasse das folgende Telefongespräch in 3-5 Sätzen sachlich zusammen.

# --- Admin-UI + Management-API (Node/Fastify; startet nur bei gesetztem Passwort) ---
ADMIN_PASSWORD=
UI_PORT=8080
# Optionaler API-Key für externen Zugriff auf /api (Header: x-api-key). Leer = nur UI-Session.
ADMIN_API_KEY=
# Secret zum Signieren des Session-Cookies (Fallback: ADMIN_PASSWORD). In Prod eigenes Secret setzen.
ADMIN_SESSION_SECRET=

# --- Sonstiges --------------------------------------------------------------
LOG_LEVEL=info

# Spike/Diagnose: Anrufer-Audio direkt zurückspielen (ohne Deepgram).
# Für den Audio-Pfad-Test (Plan-Phase 1). In Produktion immer false.
ECHO_TEST=false
