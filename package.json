{
  "name": "exius-voice-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Telefonisch erreichbarer KI-Voice-Agent: Asterisk (ARI) <-> Deepgram Voice Agent API",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "node dist/scripts/seedAgents.js",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "ari-client": "^2.2.0",
    "dotenv": "^16.4.5",
    "mongoose": "^8.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
