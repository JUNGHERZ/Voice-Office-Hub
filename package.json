{
  "name": "voice-office-hub",
  "version": "0.6.22",
  "private": true,
  "description": "Voice-Office-Hub — telefonisch erreichbarer KI-Voice-Agent: Asterisk (ARI) <-> Deepgram Voice Agent API",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "node dist/scripts/seedAgents.js",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/http-proxy": "^11.6.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@jungherz-de/glasskit": "^1.6.0",
    "@jungherz-de/glasskit-elements": "^1.6.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ari-client": "^2.2.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "hybrids": "^9.1.22",
    "mongoose": "^8.6.0",
    "sip.js": "^0.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
